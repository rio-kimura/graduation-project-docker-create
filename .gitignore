# ==============================================================================
# 🎓 卒業制作インフラ基盤：手動検証環境専用 .gitignore
# [機密情報の流出防止 ＆ 巨大バイナリデータの追跡除外]
# ==============================================================================

# 1. データベース実データの追跡除外（Gitの肥大化とパーミッション不整合を防止）
templates/supabase_db_data/

# 2. ローカル検証用環境変数の除外（本番パスワード・シークレットの流出防止）
templates/.env

# 3. OSやエディタの自動生成ゴミファイルの除外
.DS_Store
Thumbs.db
*.log
